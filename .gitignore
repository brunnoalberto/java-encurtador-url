# ==========================================
# Regras Globais / Compilação Geral
# ==========================================
# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# ==========================================
# Regras do Spring Boot & Build Tools (Maven/Gradle)
# ==========================================
HELP.md
target/
build/
.mvn/wrapper/maven-wrapper.jar

# Garante que artefatos de build criados dentro de src não sejam ignorados por engano
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

